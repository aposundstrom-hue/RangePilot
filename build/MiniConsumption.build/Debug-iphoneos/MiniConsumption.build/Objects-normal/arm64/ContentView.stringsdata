          "startingLine": 7210
        }
      },
      {
        "comment": "",
        "key": "Drag the battery or the range ring to adjust battery level.\n\nThen change driving conditions below to estimate range and charging needs.",
        "location": {
          "startingColumn": 22,
          "startingLine": 7213
        }
      },
      {
        "comment": "",
        "key": "Log actual consumption",
        "location": {
          "startingColumn": 20,
