      },
      {
        "comment": "",
        "key": "Welcome",
        "location": {
          "startingColumn": 22,
          "startingLine": 7823
        }
      },
      {
        "comment": "",
        "key": "Welcome to Mini Range\n\nDrag the battery slider to see the estimated range.\n\nChange vehicle profile and driving conditions to explore different range scenarios.",
        "location": {
          "startingColumn": 22,
          "startingLine": 7826
        }
      },
      {
        "comment": "",
        "key": "Log actual consumption",
        "location": {
          "startingColumn": 20,
          "startingLine": 7855
        }
      },
      {
        "comment": "",
        "key": "Plan a trip",
        "location": {
          "startingColumn": 20,
          "startingLine": 7868
        }
      },
      {
        "comment": "",
        "key": "Custom profile",
        "location": {
          "startingColumn": 20,
          "startingLine": 7883
        }
      },
      {
        "comment": "",
        "key": "Got it!",
        "location": {
          "startingColumn": 24,
          "startingLine": 7856
        }
      },
      {
        "comment": "",
        "key": "Log examples of your car's actual consumption to calibrate the app to your car and your real-world driving.\n\nCalibration becomes active after at least 3 logged trips.\n\nYou can turn calibration on or off at any time in Settings.",
        "location": {
          "startingColumn": 22,
          "startingLine": 7860
        }
      },
      {
        "comment": "",
        "key": "Got it!",
        "location": {
          "startingColumn": 24,
          "startingLine": 7869
        }
      },
      {
        "comment": "",
        "key": "Enter a destination, address, or place name.\n\nYou can also describe a trip in your own words.\n\nExample:\n\n\"From San Francisco to Santa Cruz\"",
        "location": {
          "startingColumn": 22,
          "startingLine": 7873
        }
      },
      {
        "comment": "",
        "key": "Continue",
        "location": {
          "startingColumn": 24,
          "startingLine": 7884
        }
      },
      {
        "comment": "",
        "key": "Cancel",
        "location": {
          "startingColumn": 24,
          "startingLine": 7888
        }
      },
      {
        "comment": "",
        "key": "Mini Range was originally modelled on the MINI Cooper SE 2019–2023.\n\nCustom profiles allow you to use the app with other electric vehicles by entering battery capacity, WLTP range, and charging speed.\n\nCustom EV estimates are approximate at first. Trip logging can calibrate estimates to your vehicle after at least three logged trips in a driving mode.\n\nIf you want to use the app for your MINI Cooper SE again, select the built-in MINI profile.",
        "location": {
          "startingColumn": 22,
          "startingLine": 7892
        }
      },
      {
        "comment": "",
        "key": "Where are you going?",
        "location": {
          "startingColumn": 23,
          "startingLine": 7915
        }
      },
      {
        "comment": "",
        "key": "Clear destination",
        "location": {
          "startingColumn": 37,
          "startingLine": 7933
        }
      },
      {
        "comment": "",
        "key": "Starts a new trip planning session.",
        "location": {
          "startingColumn": 36,
          "startingLine": 7934
        }
      },
      {
        "comment": "",
        "key": "Voice entry",
        "location": {
          "startingColumn": 37,
          "startingLine": 7941
        }
      },
      {
        "comment": "",
        "key": "Use keyboard dictation from the focused trip description field.",
        "location": {
          "startingColumn": 36,
          "startingLine": 7942
        }
      },
      {
