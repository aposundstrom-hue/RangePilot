      },
      {
        "comment": "",
        "key": "About the app",
        "location": {
          "startingColumn": 30,
          "startingLine": 7497
        }
      },
      {
        "comment": "",
        "key": "Mini Range helps electric vehicle drivers estimate real-world range and charging needs.",
        "location": {
          "startingColumn": 30,
          "startingLine": 7486
        }
      },
      {
        "comment": "",
        "key": "Adjust battery level and driving conditions to see how temperature, speed, wind, road surface, tyres, and other factors affect expected range.",
        "location": {
          "startingColumn": 30,
          "startingLine": 7487
        }
      },
      {
        "comment": "",
        "key": "Create custom vehicle profiles, log trips, and optionally calibrate estimates to match your own vehicle and driving habits over time.",
        "location": {
          "startingColumn": 30,
          "startingLine": 7488
        }
      },
      {
        "comment": "",
        "key": "The app focuses on quick, understandable estimates for everyday driving and simpler trip planning. It is intentionally lighter and simpler than full route-planning tools.",
        "location": {
          "startingColumn": 30,
          "startingLine": 7489
        }
      },
      {
        "comment": "",
        "key": "All data remains stored locally on your device.",
        "location": {
          "startingColumn": 30,
          "startingLine": 7490
        }
      },
      {
        "comment": "",
        "key": "Done",
